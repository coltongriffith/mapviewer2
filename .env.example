# ── Public client config (VITE_ prefix = compiled into the browser bundle; never secret)

# Supabase project URL + anon key. Production-required: without them, auth,
# cloud saves, shared maps, and Quebec claims search disable themselves.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Controls admin dashboard VISIBILITY only (client-side UI gate). Real admin
# authorization is server-side: the admin_users table + is_admin().
VITE_ADMIN_EMAIL=

# ── Server-only secrets (set in Vercel project env; never referenced in src/)

# Service-role key used by /api/track to write analytics tables after the
# ingest lockdown migration (20260710000004). PRODUCTION-REQUIRED once that
# migration is applied; before then analytics fall back silently.
# NEVER expose this to the client or commit a real value.
SUPABASE_SERVICE_ROLE_KEY=

# Optional: unlocks the claims-API diagnostic modes (?schema=raw / ?schema=1)
# in production via the x-admin-secret request header. Leave unset to keep
# diagnostics disabled in production.
ADMIN_API_SECRET=

# Optional server-side aliases; api/claims.js and api/track.js fall back to
# the VITE_-prefixed values when these are unset.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ── U.S. federal mining claims (BLM MLRS) feature

# Set to 1 to enable the United States (federal BLM claims) jurisdictions in
# the claim search + nearby-claims UI. Ships dark by default.
VITE_ENABLE_US_CLAIMS=

# Optional server-side override of the BLM MLRS ArcGIS FeatureServer used by
# /api/claims for US jurisdictions (defaults to the official "Mining Claims
# Not Closed" HUB service). Change only if BLM moves/renames the service.
BLM_MLRS_SERVICE_URL=

# ── Stripe billing (server-only; see docs/billing.md for full setup)

# Secret API key from the Stripe dashboard (sk_live_... / sk_test_...).
# Billing endpoints return 503 "not configured" until this is set.
STRIPE_SECRET_KEY=

# Webhook signing secret (whsec_...) for the /api/stripe-webhook endpoint —
# created when you add the webhook in the Stripe dashboard.
STRIPE_WEBHOOK_SECRET=

# Price IDs (price_...) for the Pro subscription, created in the Stripe
# dashboard. Display amounts live in src/utils/pricing.js — keep them in
# sync with these Prices.
STRIPE_PRICE_MONTHLY_ID=
STRIPE_PRICE_YEARLY_ID=

# Optional absolute site URL used for Checkout success/cancel redirects
# (defaults to https://www.explorationmaps.com).
SITE_URL=
