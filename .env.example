# Sentry error tracking
# Get your DSN from https://sentry.io → Project Settings → Client Keys
# Leave empty to disable (safe no-op)
VITE_SENTRY_DSN=

# Analytics
# Set to any non-empty value to enable the analytics send() stub in src/utils/analytics.js
# Replace the stub with your chosen provider SDK (PostHog, Mixpanel, Plausible, etc.)
VITE_ANALYTICS_KEY=
