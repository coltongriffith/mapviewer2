{
  "rewrites": [
    {
      "source": "/map/:id",
      "destination": "/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https://*.basemaps.cartocdn.com https://server.arcgisonline.com https://*.tile.opentopomap.org https://*.tiles.openrailwaymap.org https://tile.openstreetmap.org; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://va.vercel-scripts.com; object-src 'none'; frame-ancestors 'none';"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), interest-cohort=()"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/blog/location-map-:loc/",
      "destination": "/blog/how-to-create-exploration-map-investor-presentation/",
      "permanent": true
    },
    {
      "source": "/blog/target-generation-map-:loc/",
      "destination": "/blog/how-to-create-target-generation-map/",
      "permanent": true
    },
    {
      "source": "/blog/infrastructure-map-:loc/",
      "destination": "/blog/how-to-create-infrastructure-map/",
      "permanent": true
    },
    {
      "source": "/blog/mineral-exploration-map-for-investor-deck/",
      "destination": "/blog/how-to-create-exploration-map-investor-presentation/",
      "permanent": true
    },
    {
      "source": "/blog/turn-public-mineral-claim-data-into-project-map/",
      "destination": "/blog/how-to-make-a-mining-claims-map/",
      "permanent": true
    }
  ]
}